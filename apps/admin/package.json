  "devDependencies": {
    "@bhu-scms/eslint-config": "workspace:*",
    "@bhu-scms/typescript-config": "workspace:*",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "vite": "6.3.5",
