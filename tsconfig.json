{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "BHU-SCMS Root",
  "extends": "./tooling/typescript/node.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true
  },
  "include": ["*.js", "*.cjs", "tooling/**/*.js", "tooling/**/*.cjs"],
  "exclude": ["node_modules", "dist", "build", "storybook-static", "coverage", ".turbo"]
}
